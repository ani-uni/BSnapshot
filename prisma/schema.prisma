generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  mid           BigInt  @id
  uname         String
  vip           Boolean
  bauth_cookies String
}

model Config {
  id          Int @id @default(0)
  // RT 实时弹幕：调度间隔与单次拉取的任务数
  rtIntervalSec  Int @default(7200)
  rtBatch        Int @default(10)
  // HIS 历史弹幕：调度间隔、单次拉取任务数、单任务抓取的天数
  hisIntervalSec Int @default(1800)
  hisBatch       Int @default(5)
  hisBatchDays   Int @default(3)
  // SP 特殊弹幕：调度间隔与单次拉取任务数
  spIntervalSec  Int @default(86400)
  spBatch        Int @default(5)
  // UP 创作中心弹幕：调度间隔与单次拉取任务数
  upIntervalSec  Int @default(7200)
  upBatch        Int @default(5)
}

enum TaskStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// 采集目标（A）：记录某个 cid 的发布信息、时间片与其派生的 segs
model Capture {
  cid   BigInt   @id // 视频 cid
  pub   DateTime?
  clips Clip[]   // 时间段数组，表示需要爬取的时间段
  segs  String   // Int[] <- str.split(',')，由 clips 计算得到并存储
  // 对应UP主，用于 UP 任务的用户绑定
  upMid BigInt?
  tasks FetchTask[]
}

// 任务类型（C）
enum TaskType {
  RT   // 实时弹幕，与 clips/segs 强相关
  HIS  // 历史弹幕，记录已获取到的日期
  SP   // 特殊弹幕，请求方式固定
  UP   // 创作中心弹幕，以发送时间为锚点
}

// 获取任务（C）：按类型拆分任务记录，便于调度与重试
model FetchTask {
  id           String    @id @default(cuid())
  cid          BigInt
  capture      Capture   @relation(fields: [cid], references: [cid], onDelete: Cascade)
  type         TaskType
  status       TaskStatus @default(PENDING)
  nextRunAt    DateTime?
  lastRunAt    DateTime?
  // 上一次执行使用的用户，用于避免连续使用同一用户
  lastUserMid  BigInt?
  // 历史类任务游标
  hisDateCursor DateTime? // HIS：已获取到哪一天
  upCursor      DateTime? // UP：以弹幕发送时间为锚点

  @@index([cid, type, status, nextRunAt])
}

// 数据管理的最小单位
model Clip {
  id      String @id @default(cuid())
  capture Capture @relation(fields: [cid], references: [cid], onDelete: Cascade)
  cid     BigInt
  // collection   Collection? @relation(fields: [collectionId], references: [id])
  // collectionId String?
  start   Int // 开始时间（秒）
  end     Int // 结束时间（秒）
}
