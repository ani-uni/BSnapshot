generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  mid           BigInt  @id
  uname         String
  vip           Boolean
  bauth_cookies String
}

// 单次执行的最小单位
model Task {
  cid   BigInt  @id // 视频 cid
  // title String? // 任务标题
  clips Clip[] // 时间段数组，表示需要爬取的时间段
}

// 数据管理的最小单位
model Clip {
  id      String @id @default(cuid())
  task    Task   @relation(fields: [taskCid], references: [cid], onDelete: Cascade)
  taskCid BigInt
  // collection   Collection? @relation(fields: [collectionId], references: [id])
  // collectionId String?
  start   Int // 开始时间（秒）
  end     Int // 结束时间（秒）
}
